# Copy this file to .env.local and fill in your Firebase project values.
# Then add the same keys in Vercel → Project Settings → Environment Variables.
#
# How to get these values:
#   1. Go to https://console.firebase.google.com
#   2. Create a project (or open an existing one)
#   3. Build → Realtime Database → Create database → Start in test mode
#   4. Project Settings → Your apps → Add web app → copy the config block
#
# Realtime Database rules (Realtime Database → Rules tab):
#   { "rules": { ".read": true, ".write": true } }

VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_DATABASE_URL=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_APP_ID=
